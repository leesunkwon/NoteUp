<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dashboard_drawer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/noteup_background"
    tools:context=".ui.dashboard.DashboardFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="@dimen/screen_content_padding">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/navigation_button"
            style="@style/Widget.NoteUp.Button.Utility"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/open_navigation"
            android:text="@string/open_navigation"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/content_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_small"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.NoteUp.Heading"
            app:layout_constraintBottom_toBottomOf="@id/navigation_button"
            app:layout_constraintEnd_toStartOf="@id/new_note_button"
            app:layout_constraintStart_toEndOf="@id/navigation_button"
            app:layout_constraintTop_toTopOf="@id/navigation_button"
            tools:text="모든 노트" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/new_note_button"
            style="@style/Widget.NoteUp.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/new_note"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/dashboard_header_bottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="navigation_button,content_title,new_note_button" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/search_input_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_medium"
            android:hint="@string/search_notes_hint"
            app:boxBackgroundColor="@color/noteup_soft_cloud"
            app:boxCornerRadiusBottomEnd="@dimen/control_corner_radius"
            app:boxCornerRadiusBottomStart="@dimen/control_corner_radius"
            app:boxCornerRadiusTopEnd="@dimen/control_corner_radius"
            app:boxCornerRadiusTopStart="@dimen/control_corner_radius"
            app:boxStrokeColor="@color/noteup_ink"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="2dp"
            app:endIconMode="clear_text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dashboard_header_bottom">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/search_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:minHeight="@dimen/control_height" />
        </com.google.android.material.textfield.TextInputLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/note_grid"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/spacing_medium"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/spacing_large"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/search_input_layout"
            tools:listitem="@layout/item_note" />

        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/search_input_layout"
            tools:visibility="visible">

            <TextView
                android:id="@+id/empty_state_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/empty_notes_title"
                android:textAppearance="@style/TextAppearance.NoteUp.Title" />

            <TextView
                android:id="@+id/empty_state_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                android:text="@string/empty_notes_description"
                android:textAppearance="@style/TextAppearance.NoteUp.Body" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/dashboard_navigation"
        android:layout_width="@dimen/sidebar_width"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/noteup_sidebar"
        android:elevation="0dp"
        android:orientation="vertical"
        android:padding="@dimen/spacing_large">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.04"
            android:text="@string/dashboard_title"
            android:textAppearance="@style/TextAppearance.NoteUp.Title" />

        <TextView
            android:id="@+id/all_notes_button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/sidebar_item_height"
            android:layout_marginTop="@dimen/spacing_large"
            android:background="@drawable/bg_sidebar_item"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/spacing_medium"
            android:text="@string/all_notes"
            android:textAppearance="@style/TextAppearance.NoteUp.BodyStrong"
            android:textColor="@color/noteup_navigation_text" />

        <TextView
            android:id="@+id/unfiled_notes_button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/sidebar_item_height"
            android:background="@drawable/bg_sidebar_item"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/spacing_medium"
            android:text="@string/unfiled_notes"
            android:textAppearance="@style/TextAppearance.NoteUp.BodyStrong"
            android:textColor="@color/noteup_navigation_text" />

        <TextView
            android:id="@+id/trash_button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/sidebar_item_height"
            android:background="@drawable/bg_sidebar_item"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/spacing_medium"
            android:text="@string/trash"
            android:textAppearance="@style/TextAppearance.NoteUp.BodyStrong"
            android:textColor="@color/noteup_navigation_text" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_medium"
            android:layout_marginTop="@dimen/spacing_large"
            android:text="@string/notebooks"
            android:textAppearance="@style/TextAppearance.NoteUp.CaptionSmall" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/notebook_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/spacing_small"
            android:layout_weight="1"
            android:clipToPadding="false"
            tools:listitem="@layout/item_notebook" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/add_notebook_button"
            style="@style/Widget.NoteUp.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/add_notebook" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/open_settings_button"
            style="@style/Widget.NoteUp.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/open_settings" />
    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>
