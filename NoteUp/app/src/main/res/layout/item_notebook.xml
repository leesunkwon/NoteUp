<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/notebook_item"
    android:layout_width="match_parent"
    android:layout_height="@dimen/sidebar_item_height"
    android:background="@drawable/bg_sidebar_item"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="@dimen/spacing_medium">

    <TextView
        android:id="@+id/notebook_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:textAppearance="@style/TextAppearance.NoteUp.Body"
        tools:text="업무 노트" />

    <ImageButton
        android:id="@+id/notebook_more_button"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/more_options"
        android:padding="12dp"
        android:src="@drawable/ic_more_vert" />
</LinearLayout>
