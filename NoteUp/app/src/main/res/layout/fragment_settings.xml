<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/noteup_background"
    android:padding="@dimen/screen_content_padding"
    tools:context=".ui.settings.SettingsFragment">

    <TextView
        android:id="@+id/settings_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_title"
        android:textAppearance="@style/TextAppearance.NoteUp.Title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/trash_retention_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_large"
        android:background="@drawable/bg_settings_row"
        android:clickable="true"
        android:focusable="true"
        android:minHeight="@dimen/settings_row_min_height"
        android:orientation="vertical"
        android:paddingVertical="@dimen/spacing_medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/settings_title">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/trash_retention_title"
                android:textAppearance="@style/TextAppearance.NoteUp.BodyStrong" />

            <TextView
                android:id="@+id/trash_retention_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                android:textAppearance="@style/TextAppearance.NoteUp.Caption"
                tools:text="@string/trash_retention_30_days" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_small"
        android:text="@string/settings_placeholder"
        android:textAppearance="@style/TextAppearance.NoteUp.Body"
        app:layout_constraintStart_toStartOf="@id/settings_title"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/settings_title" />

</androidx.constraintlayout.widget.ConstraintLayout>
