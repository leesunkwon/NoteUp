<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_small"
    android:background="@drawable/bg_page_thumbnail_item"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:padding="@dimen/spacing_small">

    <ImageView
        android:id="@+id/page_preview"
        android:layout_width="match_parent"
        android:layout_height="@dimen/page_thumbnail_height"
        android:background="@drawable/bg_note_preview"
        android:contentDescription="@string/page_preview"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/page_number"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textStyle="bold"
            tools:text="1페이지" />

        <TextView
            android:id="@+id/page_template"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/noteup_secondary_text"
            tools:text="백지" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/delete_page_button"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/delete" />
    </LinearLayout>
</LinearLayout>
