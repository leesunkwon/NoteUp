<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/noteup_surface"
    tools:context=".ui.canvas.CanvasFragment">

    <LinearLayout
        android:id="@+id/canvas_toolbar"
        android:layout_width="0dp"
        android:layout_height="@dimen/canvas_toolbar_height"
        android:background="@drawable/bg_toolbar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/back_button"
            style="@style/Widget.NoteUp.Button.IconUtility"
            android:layout_width="@dimen/control_height"
            android:layout_height="@dimen/control_height"
            app:icon="@drawable/ic_arrow_back" />

        <TextView
            android:id="@+id/note_title"
            android:layout_width="@dimen/canvas_title_width"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_medium"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.NoteUp.Body"
            android:fontFamily="sans-serif-medium"
            tools:text="새 노트" />

        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="@dimen/spacing_small"
            android:layout_weight="1"
            android:fillViewport="false"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pen_tool_button"
                    style="@style/Widget.NoteUp.Button.IconTool"
                    android:layout_width="@dimen/control_height"
                    android:layout_height="@dimen/control_height"
                    app:icon="@drawable/ic_tool_pen" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/highlighter_tool_button"
                    style="@style/Widget.NoteUp.Button.IconTool"
                    android:layout_width="@dimen/control_height"
                    android:layout_height="@dimen/control_height"
                    app:icon="@drawable/ic_tool_highlighter" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/eraser_tool_button"
                    style="@style/Widget.NoteUp.Button.IconTool"
                    android:layout_width="@dimen/control_height"
                    android:layout_height="@dimen/control_height"
                    app:icon="@drawable/ic_tool_eraser" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/lasso_tool_button"
                    style="@style/Widget.NoteUp.Button.IconTool"
                    android:layout_width="@dimen/control_height"
                    android:layout_height="@dimen/control_height"
                    app:icon="@drawable/ic_tool_lasso" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/shape_tool_button"
                    style="@style/Widget.NoteUp.Button.IconTool"
                    android:layout_width="@dimen/control_height"
                    android:layout_height="@dimen/control_height"
                    app:icon="@drawable/ic_tool_shape" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/text_tool_button"
                    style="@style/Widget.NoteUp.Button.IconTool"
                    android:layout_width="@dimen/control_height"
                    android:layout_height="@dimen/control_height"
                    app:icon="@drawable/ic_tool_text" />
            </LinearLayout>
        </HorizontalScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/undo_button"
            style="@style/Widget.NoteUp.Button.IconUtility"
            android:layout_width="@dimen/control_height"
            android:layout_height="@dimen/control_height"
            android:enabled="false"
            app:icon="@drawable/ic_undo" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/redo_button"
            style="@style/Widget.NoteUp.Button.IconUtility"
            android:layout_width="@dimen/control_height"
            android:layout_height="@dimen/control_height"
            android:enabled="false"
            app:icon="@drawable/ic_redo" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/more_button"
            style="@style/Widget.NoteUp.Button.IconUtility"
            android:layout_width="@dimen/control_height"
            android:layout_height="@dimen/control_height"
            app:icon="@drawable/ic_more_vert" />

        <TextView
            android:id="@+id/save_status"
            android:layout_width="@dimen/save_status_width"
            android:layout_height="wrap_content"
            android:gravity="end|center_vertical"
            android:text="@string/saved"
            android:textColor="@color/noteup_secondary_text" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/context_toolbar"
        android:layout_width="0dp"
        android:layout_height="@dimen/canvas_context_toolbar_height"
        android:background="@drawable/bg_toolbar"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/canvas_toolbar">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_large">

                <TextView
                    android:id="@+id/lasso_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lasso_select_hint"
                    android:textColor="@color/noteup_secondary_text"
                    android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/edit_text_button"
                style="@style/Widget.NoteUp.Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/edit_text"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                    android:id="@+id/copy_selection_button"
                    style="@style/Widget.NoteUp.Button.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/copy_selection"
                    android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                    android:id="@+id/paste_selection_button"
                    style="@style/Widget.NoteUp.Button.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/paste_selection"
                    android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                    android:id="@+id/delete_selection_button"
                    style="@style/Widget.NoteUp.Button.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/delete_selection"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/black_color_button"
                    android:layout_width="@dimen/pen_color_button_size"
                    android:layout_height="@dimen/pen_color_button_size"
                    android:layout_marginStart="@dimen/spacing_small"
                    android:contentDescription="@string/pen_color_black"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    app:backgroundTint="@color/pen_black"
                    app:cornerRadius="@dimen/pen_color_corner_radius"
                    app:strokeColor="@color/noteup_on_surface" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/blue_color_button"
                    android:layout_width="@dimen/pen_color_button_size"
                    android:layout_height="@dimen/pen_color_button_size"
                    android:layout_marginStart="@dimen/spacing_small"
                    android:contentDescription="@string/pen_color_blue"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    app:backgroundTint="@color/pen_blue"
                    app:cornerRadius="@dimen/pen_color_corner_radius"
                    app:strokeColor="@color/noteup_on_surface" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/red_color_button"
                    android:layout_width="@dimen/pen_color_button_size"
                    android:layout_height="@dimen/pen_color_button_size"
                    android:layout_marginStart="@dimen/spacing_small"
                    android:contentDescription="@string/pen_color_red"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    app:backgroundTint="@color/pen_red"
                    app:cornerRadius="@dimen/pen_color_corner_radius"
                    app:strokeColor="@color/noteup_on_surface" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/green_color_button"
                    android:layout_width="@dimen/pen_color_button_size"
                    android:layout_height="@dimen/pen_color_button_size"
                    android:layout_marginStart="@dimen/spacing_small"
                    android:contentDescription="@string/pen_color_green"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    app:backgroundTint="@color/pen_green"
                    app:cornerRadius="@dimen/pen_color_corner_radius"
                    app:strokeColor="@color/noteup_on_surface" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/stroke_eraser_mode_button"
                    style="@style/Widget.NoteUp.Button.Tool"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_small"
                    android:text="@string/stroke_eraser_mode"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/area_eraser_mode_button"
                    style="@style/Widget.NoteUp.Button.Tool"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/area_eraser_mode"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/thin_button"
                    style="@style/Widget.NoteUp.Button.Tool"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_small"
                    android:text="@string/pen_thin" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/medium_button"
                    style="@style/Widget.NoteUp.Button.Tool"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pen_medium" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/thick_button"
                    style="@style/Widget.NoteUp.Button.Tool"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pen_thick" />

            </LinearLayout>
        </HorizontalScrollView>

    <com.kotlinsun.noteup.ui.canvas.DrawingCanvasView
        android:id="@+id/drawing_canvas"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/noteup_surface"
        android:contentDescription="@string/canvas_title"
        app:layout_constraintBottom_toTopOf="@id/page_navigation_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/context_toolbar" />

    <LinearLayout
        android:id="@+id/page_navigation_bar"
        android:layout_width="0dp"
        android:layout_height="@dimen/page_navigation_height"
        android:background="@drawable/bg_top_hairline"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/page_list_button"
            style="@style/Widget.NoteUp.Button.Utility"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/page_list" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/previous_page_button"
            style="@style/Widget.NoteUp.Button.Utility"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/previous_page" />

        <TextView
            android:id="@+id/page_indicator"
            android:layout_width="@dimen/page_indicator_width"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textAppearance="@style/TextAppearance.NoteUp.BodyStrong"
            tools:text="1 / 3" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/next_page_button"
            style="@style/Widget.NoteUp.Button.Utility"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/next_page" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/add_page_button"
            style="@style/Widget.NoteUp.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_page" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/zoom_controls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_medium"
        app:cardBackgroundColor="@color/noteup_canvas"
        app:cardCornerRadius="@dimen/zoom_floating_corner_radius"
        app:cardElevation="@dimen/zoom_floating_elevation"
        app:layout_constraintBottom_toTopOf="@id/page_navigation_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="@color/noteup_hairline_soft"
        app:strokeWidth="@dimen/hairline_width">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_extra_small">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/zoom_out_button"
                style="@style/Widget.NoteUp.Button.IconUtility"
                android:layout_width="@dimen/control_height"
                android:layout_height="@dimen/control_height"
                android:contentDescription="@string/zoom_out"
                android:text="@string/zoom_out_symbol" />

            <TextView
                android:id="@+id/zoom_percentage"
                android:layout_width="@dimen/zoom_percentage_width"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/zoom_percentage_default"
                android:textAppearance="@style/TextAppearance.NoteUp.BodyStrong"
                tools:text="125%" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/zoom_reset_button"
                style="@style/Widget.NoteUp.Button.Utility"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/control_height"
                android:contentDescription="@string/zoom_reset"
                android:minWidth="@dimen/control_height"
                android:paddingHorizontal="@dimen/spacing_small"
                android:text="@string/zoom_reset_short" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/zoom_in_button"
                style="@style/Widget.NoteUp.Button.IconUtility"
                android:layout_width="@dimen/control_height"
                android:layout_height="@dimen/control_height"
                android:contentDescription="@string/zoom_in"
                android:text="@string/zoom_in_symbol" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/page_panel"
        android:layout_width="@dimen/page_panel_width"
        android:layout_height="0dp"
        android:layout_margin="0dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/noteup_canvas"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/noteup_hairline"
        app:strokeWidth="@dimen/hairline_width"
        app:layout_constraintBottom_toTopOf="@id/page_navigation_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/context_toolbar"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/spacing_small">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/page_list"
                    android:textAppearance="@style/TextAppearance.NoteUp.BodyStrong" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/close_page_panel_button"
                    style="@style/Widget.NoteUp.Button.Utility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/close" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/page_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="@dimen/spacing_small"
                tools:listitem="@layout/item_page_thumbnail" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/loading_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@id/drawing_canvas"
        app:layout_constraintEnd_toEndOf="@id/drawing_canvas"
        app:layout_constraintStart_toStartOf="@id/drawing_canvas"
        app:layout_constraintTop_toTopOf="@id/drawing_canvas" />

    <LinearLayout
        android:id="@+id/not_found_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/drawing_canvas"
        app:layout_constraintEnd_toEndOf="@id/drawing_canvas"
        app:layout_constraintStart_toStartOf="@id/drawing_canvas"
        app:layout_constraintTop_toTopOf="@id/drawing_canvas"
        tools:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/canvas_not_found_title"
            android:textAppearance="@style/TextAppearance.NoteUp.Title" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_small"
            android:text="@string/canvas_not_found_description"
            android:textAppearance="@style/TextAppearance.NoteUp.Body" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
