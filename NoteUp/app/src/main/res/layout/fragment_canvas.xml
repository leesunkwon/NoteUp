<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/noteup_surface"
    android:padding="@dimen/screen_content_padding"
    tools:context=".ui.canvas.CanvasFragment">

    <TextView
        android:id="@+id/canvas_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/canvas_title"
        android:textAppearance="@style/TextAppearance.NoteUp.Title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_small"
        android:text="@string/canvas_placeholder"
        android:textAppearance="@style/TextAppearance.NoteUp.Body"
        app:layout_constraintStart_toStartOf="@id/canvas_title"
        app:layout_constraintTop_toBottomOf="@id/canvas_title" />

</androidx.constraintlayout.widget.ConstraintLayout>
